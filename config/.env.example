# Threads API
# Meta Developer Portal (developers.facebook.com) で取得
THREADS_ACCESS_TOKEN=your_long_lived_access_token_here

# 画像を公開URLとしてホストするための Imgur Client ID
# https://api.imgur.com/oauth2/addclient で無料取得
IMGUR_CLIENT_ID=your_imgur_client_id_here

# 投稿設定
IMAGES_FOLDER=./images
POST_MIN_INTERVAL=60        # 投稿間隔の最小値（分）
POST_MAX_INTERVAL=180       # 投稿間隔の最大値（分）
DEFAULT_HASHTAGS=#スキンケア #美容 #skincare #美肌
